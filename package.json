{
  "name": "latency",
  "displayName": "Latency",
  "description": "A VS Code extension for latency tooling.",
  "version": "0.0.1",
  "publisher": "latency-dev",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
